# Supabase — same project as promptline-secure
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Zoho federated login (client) — public app id, safe in the bundle.
# Omit to hide the "Continue with Zoho" button.
VITE_ZOHO_CLIENT_ID=

# Zoho federated login (server / Vercel functions only) — NEVER prefix with VITE_.
# Used by api/zoho/session.js to exchange the OAuth code server-side.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Service-role key for minting sessions in the function (same value as the VITE_
# one above, but kept un-prefixed so it is never bundled into the browser).
SUPABASE_SERVICE_ROLE_KEY=
