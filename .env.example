# Supabase — same project as promptline-secure
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SERVICE_ROLE_KEY=

# Sentry error monitoring (project "promptline-web").
# Public DSN (safe to embed); the app falls back to this literal if unset.
VITE_SENTRY_DSN=https://7887d63331c983a15f0e09124cbea3bb@o4511564677447680.ingest.us.sentry.io/4511564682297344
# Explicit Sentry environment tag. Do NOT infer from the Supabase URL — the prod
# frontend still points at the sandbox Supabase project until cutover.
VITE_APP_ENV=sandbox

# Zoho federated login (client) — public app id, safe in the bundle.
# Omit to hide the "Continue with Zoho" button.
VITE_ZOHO_CLIENT_ID=

# Zoho federated login (server / Vercel functions only) — NEVER prefix with VITE_.
# Used by api/zoho/session.js to exchange the OAuth code server-side.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Service-role key for minting sessions in the function (same value as the VITE_
# one above, but kept un-prefixed so it is never bundled into the browser).
SUPABASE_SERVICE_ROLE_KEY=
